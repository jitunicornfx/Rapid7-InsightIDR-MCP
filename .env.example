# Rapid7 InsightIDR MCP server configuration.
# Copy to `.env` and fill in, or export these variables in your MCP client config.

# REQUIRED: Insight platform API key (Administration > API Keys > Organization key).
INSIGHTIDR_API_KEY=your-insight-platform-api-key

# OPTIONAL: Insight region code. One of: us, us2, us3, eu, ca, au, ap. Defaults to "us".
INSIGHTIDR_REGION=us

# OPTIONAL: Override the full base URL (advanced / testing only).
# Defaults to https://<region>.api.insight.rapid7.com
# INSIGHTIDR_BASE_URL=https://us.api.insight.rapid7.com

# OPTIONAL: Override the v1 API base URL.
# Defaults to https://<region>.rest.logs.insight.rapid7.com (per the v1 spec's servers).
# Set to https://<region>.api.insight.rapid7.com if your tenant routes v1 there.
# INSIGHTIDR_V1_BASE_URL=https://us.rest.logs.insight.rapid7.com

# OPTIONAL: Override the Log Search API base URL.
# Defaults to https://<region>.rest.logs.insight.rapid7.com (per the Log Search spec's servers).
# Set this to the unified platform route if preferred:
# INSIGHTIDR_LOG_SEARCH_BASE_URL=https://us.api.insight.rapid7.com/log_search

# OPTIONAL: Per-request timeout in milliseconds. Defaults to 60000.
# INSIGHTIDR_TIMEOUT_MS=60000

# OPTIONAL (--http mode only): comma-separated browser origins allowed via CORS.
# Empty (default) denies all cross-origin browser access; non-browser MCP clients are unaffected.
# Never use "*". Example:
# INSIGHTIDR_HTTP_ALLOWED_ORIGINS=https://app.example.com,https://another.example.com:8443
